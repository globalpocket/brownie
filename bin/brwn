#!/usr/bin/env python3
import sys
import os
import signal
import subprocess
import argparse
import fcntl
from pathlib import Path

# プロジェクトルートをパスに追加
sys.path.append(os.path.join(os.path.dirname(__file__), ".."))

# 1. 二重起動防止 (設計書 3.2: PIDロック)
LOCK_FILE = "/tmp/brownie.lock"

def acquire_lock():
    pid_file = open(LOCK_FILE, "w")
    try:
        fcntl.lockf(pid_file, fcntl.LOCK_EX | fcntl.LOCK_NB)
        pid_file.write(str(os.getpid()))
        pid_file.flush()
        return pid_file
    except IOError:
        print("Error: Brownie CLI is already running.")
        sys.exit(1)

def run_command(args):
    """メインプロセス/Watchdog の制御"""
    # 仮想環境のPythonを使用する
    base_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    venv_python = os.path.join(base_dir, ".venv", "bin", "python")
    
    if args.action == "start":
        print("Starting Brownie system...")
        # Watchdog をバックグラウンドで起動
        subprocess.Popen([venv_python, "src/watchdog.py"], start_new_session=True)
    elif args.action == "stop":
        print("Stopping Brownie system...")
        # プロセスを探して kill
        try:
            with open(LOCK_FILE, "r") as f:
                pid = int(f.read())
                os.kill(pid, signal.SIGTERM)
        except Exception:
            pass
    elif args.action == "status":
        print("Brownie Status:")
        # 簡易的にプロセスが存在するか確認
        res = subprocess.run(["pgrep", "-f", "src/watchdog.py"], capture_output=True)
        if res.returncode == 0:
            print(" - Watchdog: Running")
        else:
            print(" - Watchdog: Stopped")
    elif args.action == "queue":
        print("Checking task queue...")
        # 実際には SQLite や Orchestrator の API を叩く
        pass

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Brownie CLI")
    parser.add_argument("action", choices=["start", "stop", "restart", "status", "queue", "log"])
    args = parser.parse_args()

    # 二重起動防止
    lock = acquire_lock()
    
    try:
        run_command(args)
    finally:
        # ロック解放
        lock.close()
        if os.path.exists(LOCK_FILE):
            os.remove(LOCK_FILE)
