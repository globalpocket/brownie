#!/usr/bin/env python3
import sys
import os
import signal
import subprocess
import argparse
import time
from pathlib import Path

# プロジェクトルートをパスに追加
sys.path.append(os.path.join(os.path.dirname(__file__), ".."))
from src.version import get_build_id
BUILD_ID = get_build_id()

# 1. 永続的なPIDファイル (設計書 3.2: PIDロック)
DATA_DIR = Path.home() / ".local" / "share" / "brownie"
DATA_DIR.mkdir(parents=True, exist_ok=True)
PID_FILE = DATA_DIR / "brownie.pid"
LOCK_FILE = DATA_DIR / "brownie.lock"

def get_running_pid():
    """PIDファイルと実プロセスの存在を確認"""
    if os.path.exists(PID_FILE):
        try:
            with open(PID_FILE, "r") as f:
                pid = int(f.read().strip())
                # プロセスが存在し、かつBrownie関連か確認 (簡易チェック)
                os.kill(pid, 0)
                return pid
        except (ValueError, ProcessLookupError, PermissionError):
            pass
    return None

def kill_all_brownie():
    """システム上のすべてのBrownie関連プロセス（watchdog, main）を物理的に一掃する"""
    print("🧹 Cleaning up all Brownie-related processes...")
    
    # psコマンドで、Brownieのリポジトリパスを含むPythonプロセスを探し出す
    base_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    try:
        # brownieのリポジトリパスを含むpythonプロセスを洗い出す
        # ps -eo pid,args はMac/Linux共通
        ps_cmd = f"ps -eo pid,args | grep '{base_dir}' | grep 'python' | grep -E 'watchdog\\.py|main\\.py' | grep -v 'grep'"
        output = subprocess.check_output(ps_cmd, shell=True).decode().strip()
        
        if output:
            for line in output.split("\n"):
                parts = line.strip().split()
                if not parts: continue
                pid = int(parts[0])
                if pid != os.getpid():
                    try:
                        os.kill(pid, signal.SIGKILL)
                        print(f"  - Killed process: {pid}")
                    except ProcessLookupError:
                        pass
    except Exception:
        pass # プロセスが見つからない場合は正常終了
    
    if os.path.exists(PID_FILE):
        os.remove(PID_FILE)
    
    # 生存信号ファイルも一掃
    if os.path.exists("/tmp/brownie_survival.signal"):
        try: os.remove("/tmp/brownie_survival.signal")
        except: pass

def run_command(args):
    """メインプロセス/Watchdog の制御"""
    import fcntl
    
    base_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    venv_python = os.path.join(base_dir, ".venv", "bin", "python")
    
    if args.action == "start":
        # ロックファイルで二重起動を厳格に防止
        lock_f = open(LOCK_FILE, "a")
        try:
            # 試しにロック。取れないなら誰かが動いている
            fcntl.flock(lock_f, fcntl.LOCK_EX | fcntl.LOCK_NB)
            # 取れたら他は動いていないので、一旦アンロックしてWatchdogにバトンを渡す
            fcntl.flock(lock_f, fcntl.LOCK_UN)
        except BlockingIOError:
            pid = get_running_pid()
            if pid is None:
                # ロックはされているがPIDが追跡不能な場合、残留プロセスを掃除して続行
                print("⚠️ Stale lock or untracked process found. Cleaning up...")
                kill_all_brownie()
            else:
                print(f"Error: Brownie is already running (PID: {pid}).")
                sys.exit(1)

        print(f"Starting Brownie system (Build: {BUILD_ID})...")
        process = subprocess.Popen(
            [venv_python, "src/watchdog.py"],
            start_new_session=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )
        # PIDを保存
        with open(PID_FILE, "w") as f:
            f.write(str(process.pid))
        print(f"Brownie started (Watchdog PID: {process.pid}).")

    elif args.action == "debug":
        # デバッグモードでもロックを確認
        lock_f = open(LOCK_FILE, "a")
        try:
            fcntl.flock(lock_f, fcntl.LOCK_EX | fcntl.LOCK_NB)
            # フォアグラウンドで動かす間はこのCLIがロックを持ち続ける
        except BlockingIOError:
            pid = get_running_pid()
            print(f"Error: Brownie is already running (PID: {pid or 'Unknown'}).")
            sys.exit(1)

        print(f"Starting Brownie in DEBUG mode (Build: {BUILD_ID})...")
        my_pid = os.getpid()
        with open(PID_FILE, "w") as f:
            f.write(str(my_pid))

        envs = os.environ.copy()
        envs["BROWNIE_DEBUG"] = "1"
        try:
            subprocess.run([venv_python, "src/watchdog.py"], env=envs)
        except KeyboardInterrupt:
            print("\nDebug mode stopped by user.")
        finally:
            if os.path.exists(PID_FILE):
                os.remove(PID_FILE)

    elif args.action == "stop" or args.action == "restart":
        pid = get_running_pid()
        if pid:
            print(f"Stopping Brownie system (PID: {pid})...")
            try:
                os.killpg(os.getpgid(pid), signal.SIGTERM)
                time.sleep(2)
            except:
                pass
        
        # PIDベースの停止が失敗した場合や、残留プロセスがある場合に備えて「大掃除」
        kill_all_brownie()
        
        if args.action == "restart":
            time.sleep(1)
            args.action = "start"
            run_command(args)

    elif args.action == "status":
        # ロックが取得できるなら動いていない、取得できないなら動いている
        lock_f = open(LOCK_FILE, "r+")
        running = False
        try:
            fcntl.flock(lock_f, fcntl.LOCK_EX | fcntl.LOCK_NB)
            # ロックが取れた = 動いていない
            fcntl.flock(lock_f, fcntl.LOCK_UN)
        except BlockingIOError:
            running = True
        
        pid = get_running_pid()
        if running or pid:
            print(f"Brownie is ACTIVE (PID: {pid or 'Unknown'})")
        else:
            print("Brownie is STOPPED")

    elif args.action == "logs" or args.action == "log":
        log_file = os.path.join(base_dir, "logs", "brownie.log")
        if os.path.exists(log_file):
            subprocess.run(["tail", "-f", log_file])
        else:
            print("No log file found.")

    elif args.action == "reset":
        # 1. 停止
        args.action = "stop"
        run_command(args)
        
        # 2. ファイル削除 (仮想環境のPythonを使って安全に実行)
        print("Starting cleanup process...")
        subprocess.run([venv_python, "src/utils/reset_system.py"])

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Brownie CLI")
    parser.add_argument("action", choices=["start", "stop", "restart", "status", "logs", "log", "queue", "debug", "reset"])
    args = parser.parse_args()

    run_command(args)
